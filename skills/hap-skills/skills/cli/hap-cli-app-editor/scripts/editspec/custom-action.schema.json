{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "custom-action ops",
  "description": "Deep schema for op.type starting with 'custom-action.'. A custom action is a record button; update edits the existing button in place (its shadow workflow is not rebuilt — decision #11).",
  "oneOf": [
    {
      "$ref": "#/$defs/create"
    },
    {
      "$ref": "#/$defs/update"
    }
  ],
  "$defs": {
    "create": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "worksheet"
      ],
      "properties": {
        "type": {
          "const": "custom-action.create"
        },
        "label": {
          "type": "string"
        },
        "worksheet": {
          "type": "string",
          "minLength": 1
        },
        "action_spec": {
          "type": "object",
          "description": "High-level action: {type, updateFields, relationField, enableWhen, name}. Field refs are control ids."
        },
        "config": {
          "type": "object",
          "description": "Raw button config (wire form). Use instead of action_spec for full control."
        }
      }
    },
    "update": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "worksheet",
        "action"
      ],
      "properties": {
        "type": {
          "const": "custom-action.update"
        },
        "label": {
          "type": "string"
        },
        "worksheet": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "minLength": 1,
          "description": "Target button: name or btnId."
        },
        "action_spec": {
          "type": "object"
        },
        "config": {
          "type": "object"
        }
      }
    }
  }
}
