        },
        {
          "type": "Divider",
          "name": "明细信息",
          "row": 3,
          "size": 12
        },
        {
          "type": "SubTable",
          "name": "入库明细",
          "row": 4,
          "size": 12,
          "child_fields": [
            {
              "type": "Relation",
              "name": "物料",
              "relation": {
                "worksheet": "物料",
                "multi": false,
                "display": "dropdown"
              }
            },
            {
              "type": "Number",
              "name": "入库数量"
            },
            {
              "type": "Number",
              "name": "单价",
              "decimals": 2
            }
          ]
        },
        {
          "type": "Divider",
          "name": "汇总与凭证",
          "row": 5,
          "size": 12
        },
        {
          "type": "Rollup",
          "name": "入库总数量",
          "row": 6,
          "size": 6,
          "rollup": {
            "via": "入库明细",
            "field": "入库数量",
            "aggregate": "sum"
          }
        },
        {
          "type": "Text",
          "name": "审批备注",
          "hidden_on_create": true,
          "row": 6,
          "size": 6
        },
        {
          "type": "Attachment",
          "name": "凭证附件",
          "row": 7,
          "size": 12
        }
      ]
    },
    {
