            "prefix": "RK-",
            "date_format": "YYYYMMDD",
            "digits": 4,
            "reset": "daily"
          }
        },
        {
          "type": "Date",
          "name": "入库日期",
          "row": 1,
          "size": 3
        },
        {
          "type": "SingleSelect",
          "name": "入库类型",
          "options": [
            "采购入库",
            "退货入库",
            "调拨入库",
            "盘盈入库"
          ],
          "row": 1,
          "size": 3
        },
        {
          "type": "Dropdown",
          "name": "优先级",
          "optionset": "优先级集",
          "row": 1,
          "size": 3
        },
        {
          "type": "Relation",
          "name": "入库仓库",
          "relation": {
            "worksheet": "仓库",
            "multi": false,
            "display": "dropdown"
          },
          "row": 2,
          "size": 3
        },
        {
          "type": "Collaborator",
          "name": "经办人",
          "row": 2,
          "size": 3
        },
        {
          "type": "Text",
          "name": "供应商",
          "row": 2,
          "size": 3
        },
        {
          "type": "SingleSelect",
          "name": "单据状态",
          "options": [
            {
              "value": "待审批",
