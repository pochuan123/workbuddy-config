{
  "workflows": [
    {
      "name": "库存安全水位预警",
      "trigger": {
        "type": "record_update",
        "worksheet": "库存",
        "fields": [
          "当前数量"
        ]
      },
      "nodes": [
        {
          "nodeAlias": "mat",
          "nodeType": "get_relation_records",
          "name": "取关联物料",
          "config": {
            "relation_field": "库存/物料",
            "target": {
              "kind": "record",
              "node": {
                "nodeAlias": "trigger"
              }
            }
          }
        },
        {
          "nodeAlias": "chk",
          "nodeType": "branch",
          "name": "安全库存校验",
          "config": {
            "paths": [
              {
                "name": "低于安全库存",
                "condition": {
                  "items": [
                    {
                      "left": {
                        "kind": "field",
                        "node": {
                          "nodeAlias": "trigger"
                        },
                        "fieldId": "库存/当前数量"
                      },
                      "op": "lt",
                      "right": {
                        "kind": "field",
                        "node": {
                          "nodeAlias": "mat"
                        },
                        "fieldId": "物料/安全库存"
                      }
                    }
                  ]
                },
                "nodes": [
                  {
                    "nodeAlias": "warn",
                    "nodeType": "notice",
                    "name": "站内通知拥有者",
                    "config": {
                      "content": "库存「$trigger-库存/库存编号$」当前数量已低于该物料的安全库存，请及时补货。",
                      "accounts": [
                        {
                          "kind": "owner",
                          "node": {
                            "nodeAlias": "trigger"
                          }
                        }
                      ]
                    }
                  },
                  {
                    "nodeAlias": "mail",
                    "nodeType": "send_email",
                    "name": "邮件通知拥有者",
                    "config": {
                      "subject": "【库存预警】物料库存低于安全水位",
                      "content": "您负责的库存记录当前数量已低于物料安全库存，请尽快安排补货处理。",
                      "accounts": [
                        {
                          "kind": "owner",
                          "node": {
                            "nodeAlias": "trigger"
                          }
                        }
                      ]
                    }
                  }
                ]
              },
              {
                "name": "水位正常",
                "nodes": []
              }
            ]
          }
        }
      ]
    },
    {
      "name": "月度盘点提醒",
      "trigger": {
        "type": "scheduled",
        "schedule": {
          "repeat": "month",
          "interval": 1,
          "start_time": "2026-07-01 08:00"
        }
      },
      "nodes": [
        {
          "nodeAlias": "remind",
          "nodeType": "notice",
          "name": "通知组织盘点",
          "config": {
            "content": "新的月度库存盘点周期已开始，请组织仓管员对各仓库库存进行实地盘点，核对台账数量并更新盘点日期。",
            "accounts": [
              {
                "kind": "role",
                "role": "仓库主管"
              },
              {
                "kind": "role",
                "role": "库管组长"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "新入库单建单抄送复核",
      "trigger": {
        "type": "record_create",
        "worksheet": "入库单"
      },
      "nodes": [
        {
          "nodeAlias": "cc1",
          "nodeType": "cc",
          "name": "抄送仓库主管复核",
          "config": {
            "worksheet": "入库单",
            "content": "新入库单「$trigger-入库单/入库单号$」已创建（入库类型：$trigger-入库单/入库类型$，供应商：$trigger-入库单/供应商$），请核对明细后提交审批。",
            "card_fields": [
              "入库类型",
              "供应商",
              "入库总数量"
            ],
            "target": {
              "kind": "record",
              "node": {
                "nodeAlias": "trigger"
              }
            },
            "accounts": [
              {
                "kind": "role",
                "role": "仓库主管"
              },
              {
                "kind": "role",
                "role": "库管组长"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "出库单超期未出库提醒",
      "trigger": {
        "type": "date",
        "worksheet": "出库单",
        "date_field": "出库日期",
        "date_config": {
          "offset_type": "after",
          "offset_number": 3,
          "offset_unit": "day",
          "time": "09:00",
          "repeat": "once"
        }
      },
      "nodes": [
        {
          "nodeAlias": "chk",
          "nodeType": "branch",
          "name": "是否仍未完成出库",
          "config": {
            "paths": [
              {
                "name": "仍未出库",
                "condition": {
                  "items": [
                    {
                      "left": {
                        "kind": "field",
                        "node": {
                          "nodeAlias": "trigger"
                        },
                        "fieldId": "出库单/单据状态"
                      },
                      "op": "in",
                      "right": {
                        "kind": "literal",
                        "values": [
                          "未提交",
                          "审批中",
                          "已审批",
                          "待出库"
                        ]
                      }
                    }
                  ]
                },
                "nodes": [
                  {
                    "nodeAlias": "rem",
                    "nodeType": "notice",
                    "name": "催办出库",
                    "config": {
                      "content": "出库单「$trigger-出库单/出库单号$」预计出库日期已过 3 天仍未完成出库（当前状态：$trigger-出库单/单据状态$，出库类型：$trigger-出库单/出库类型$），请尽快安排出库或确认是否取消。",
                      "accounts": [
                        {
                          "kind": "owner",
                          "node": {
                            "nodeAlias": "trigger"
                          }
                        },
                        {
                          "kind": "role",
                          "role": "仓库主管"
                        }
                      ]
                    }
                  }
                ]
              },
              {
                "name": "已完成或已取消",
                "nodes": []
              }
            ]
          }
        }
      ]
    },
    {
      "name": "入库审批",
      "trigger": {
        "type": "record_update",
        "worksheet": "入库单",
        "fields": [
          "单据状态"
        ],
        "filter": {
          "items": [
            {
              "left": {
                "kind": "field",
                "node": {
                  "nodeAlias": "trigger"
                },
                "fieldId": "入库单/单据状态"
              },
              "op": "eq",
              "right": {
                "kind": "literal",
                "value": "审批中"
              }
            }
          ]
        }
      },
      "nodes": [
        {
          "nodeAlias": "appr",
          "nodeType": "approval_block",
          "name": "入库审批",
          "config": {
            "accounts": [
              {
                "kind": "triggerUser"
              }
            ],
            "process": {
              "name": "入库审批流程",
              "explain": "入库单提交后的逐级审批：加急/特急直送仓库主管，其余先经直属上司再到仓库主管。",
              "nodes": [
                {
                  "nodeAlias": "prio",
                  "nodeType": "branch",
                  "name": "优先级分流",
                  "config": {
                    "paths": [
                      {
                        "name": "加急特急",
                        "condition": {
                          "items": [
                            {
                              "left": {
                                "kind": "field",
                                "node": {
                                  "nodeAlias": "approval_trigger"
                                },
                                "fieldId": "入库单/优先级"
                              },
                              "op": "in",
                              "right": {
                                "kind": "literal",
                                "values": [
                                  "加急",
                                  "特急"
                                ]
                              }
                            }
                          ]
                        },
                        "nodes": [
                          {
                            "nodeAlias": "af",
                            "nodeType": "approve",
                            "name": "仓库主管审批",
                            "config": {
                              "accounts": [
                                {
                                  "kind": "role",
                                  "role": "仓库主管"
                                }
                              ]
                            }
                          }
                        ]
                      },
                      {
                        "name": "普通",
                        "nodes": [
                          {
                            "nodeAlias": "as",
                            "nodeType": "approve",
                            "name": "班组长审批",
                            "config": {
                              "accounts": [
                                {
                                  "kind": "role",
                                  "role": "库管组长"
                                }
                              ]
                            }
                          },
                          {
                            "nodeAlias": "am",
                            "nodeType": "approve",
                            "name": "仓库主管审批",
                            "config": {
                              "accounts": [
                                {
                                  "kind": "role",
                                  "role": "仓库主管"
                                }
                              ]
                            }
                          }
                        ]
                      }
                    ]
                  }
                }
              ]
            }
          }
        },
        {
          "nodeAlias": "detail",
          "nodeType": "get_relation_records",
          "name": "取入库明细",
          "prevNode": "appr",
          "config": {
            "relation_field": "入库单/入库明细",
            "target": {
              "kind": "record",
              "node": {
                "nodeAlias": "trigger"
              }
            }
          }
        },
        {
          "nodeAlias": "res",
          "nodeType": "branch",
          "name": "审批结果分流",
          "config": {
            "paths": [
              {
                "name": "通过入库",
                "nodes": [
                  {
                    "nodeAlias": "addstock",
                    "nodeType": "sub_process",
                    "name": "增加库存",
                    "config": {
                      "process": {
                        "name": "按入库明细增加库存",
                        "explain": "审批通过后，按入库明细逐条累加对应物料的当前库存。",
                        "data_source": {
                          "kind": "record",
                          "node": {
                            "nodeAlias": "detail"
                          }
                        },
                        "wait_complete": true,
                        "nodes": [
                          {
                            "nodeAlias": "addkc",
                            "nodeType": "query_update",
                            "name": "累加库存",
                            "config": {
                              "worksheet": "库存",
                              "execute_type": 2,
                              "filter": {
                                "items": [
                                  {
                                    "left": {
                                      "kind": "field",
                                      "node": {
                                        "nodeAlias": "addkc"
                                      },
                                      "fieldId": "库存/物料"
                                    },
                                    "op": "eq",
                                    "right": {
                                      "kind": "field",
                                      "node": {
                                        "nodeAlias": "sub_trigger"
                                      },
                                      "fieldId": "入库单/入库明细/物料"
                                    }
                                  }
                                ]
                              },
                              "fields": [
                                {
                                  "fieldId": "库存/当前数量",
                                  "type": 6,
                                  "addType": 1,
                                  "valueRef": {
                                    "node": {
                                      "nodeAlias": "sub_trigger"
                                    },
                                    "fieldId": "入库单/入库明细/入库数量",
                                    "nodeActionId": "401"
                                  }
                                }
                              ]
                            }
                          }
                        ]
                      }
                    }
                  },
                  {
                    "nodeType": "update_record",
                    "name": "通过入库",
                    "config": {
                      "worksheet": "入库单",
                      "target": {
                        "kind": "record",
                        "node": {
                          "nodeAlias": "trigger"
                        }
                      },
                      "fields": [
                        {
                          "fieldId": "入库单/单据状态",
                          "type": 9,
                          "value": "已入库"
                        }
                      ]
                    },
                    "nodeAlias": "rp"
                  }
                ],
                "condition": {
                  "items": [
                    {
                      "left": {
                        "kind": "field",
                        "node": {
                          "nodeAlias": "appr"
                        },
                        "fieldId": "result"
                      },
                      "op": "eq",
                      "right": {
                        "kind": "literal",
                        "value": "PASS"
                      }
                    }
                  ]
                }
              },
              {
                "name": "驳回",
                "nodes": [
                  {
                    "nodeType": "update_record",
                    "name": "驳回",
                    "config": {
                      "worksheet": "入库单",
                      "target": {
                        "kind": "record",
                        "node": {
                          "nodeAlias": "trigger"
                        }
                      },
                      "fields": [
                        {
                          "fieldId": "入库单/单据状态",
                          "type": 9,
                          "value": "审批未通过"
                        }
                      ]
                    },
                    "nodeAlias": "ro"
                  }
                ],
                "condition": {
                  "items": [
                    {
                      "left": {
                        "kind": "field",
                        "node": {
                          "nodeAlias": "appr"
                        },
                        "fieldId": "result"
                      },
                      "op": "eq",
                      "right": {
                        "kind": "literal",
                        "value": "OVERRULE"
                      }
                    }
                  ]
                }
              },
              {
                "name": "退回待审批",
                "nodes": [
                  {
                    "nodeType": "update_record",
                    "name": "退回待审批",
                    "config": {
                      "worksheet": "入库单",
                      "target": {
                        "kind": "record",
                        "node": {
                          "nodeAlias": "trigger"
                        }
                      },
                      "fields": [
                        {
                          "fieldId": "入库单/单据状态",
                          "type": 9,
                          "value": "待审批"
                        }
                      ]
                    },
                    "nodeAlias": "rr"
                  }
                ],
                "condition": {
                  "items": [
                    {
                      "left": {
                        "kind": "field",
                        "node": {
                          "nodeAlias": "appr"
                        },
                        "fieldId": "result"
                      },
                      "op": "eq",
                      "right": {
                        "kind": "literal",
                        "value": "REVOKE"
                      }
                    }
                  ]
                }
              },
              {
                "name": "已取消",
                "nodes": [
                  {
                    "nodeType": "update_record",
                    "name": "已取消",
                    "config": {
                      "worksheet": "入库单",
                      "target": {
                        "kind": "record",
                        "node": {
                          "nodeAlias": "trigger"
                        }
                      },
                      "fields": [
                        {
                          "fieldId": "入库单/单据状态",
                          "type": 9,
                          "value": "已取消"
                        }
                      ]
                    },
                    "nodeAlias": "rs"
                  }
                ]
              }
            ]
          }
        }
      ]
    },
